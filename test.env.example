# Podium test credentials for the integration and live-test lanes.
#
# Copy this file to test.env (gitignored) and fill in the services you have:
#     cp test.env.example test.env
#
# The test harness loads it automatically:
#   - `make test`, `make test-live`, and `make test-live-external` source it.
#   - `go test ./test/...` loads it through internal/testenv, no make needed.
#
# Values already present in your environment take precedence over this file, so
# CI keeps using its injected secrets. Each test self-skips when its variables
# are absent, so set only the services you can reach. Override the path with
# PODIUM_TEST_ENV_FILE=/path/to/env.

# ---- Live-lane switches -----------------------------------------------------
# Master switch for the managed vector and embedding suites. Off until set.
# PODIUM_LIVE_EXTERNAL=1
# Opt-in marker for the bundled-Dex device-code login e2e (make test-auth-dex).
# PODIUM_LIVE_DEX=1

# ---- Local services: Postgres + S3 (docker-compose; `make services-up`) -----
# These match docker-compose.yml. With the services up, the Postgres and S3
# integration tests take their live path; with them down, the tests skip.
PODIUM_POSTGRES_DSN=postgres://podium:podium@localhost:5432/podium?sslmode=disable
# Optional separate DSN for the pgvector depth tests (falls back to the above).
# PODIUM_POSTGRES_DSN_VECTOR=postgres://podium:podium@localhost:5432/podium?sslmode=disable
PODIUM_S3_ENDPOINT=http://localhost:9000
PODIUM_S3_BUCKET=podium
PODIUM_S3_REGION=us-east-1
PODIUM_S3_ACCESS_KEY_ID=minioadmin
PODIUM_S3_SECRET_ACCESS_KEY=minioadmin
PODIUM_S3_USE_SSL=false
PODIUM_S3_FORCE_PATH_STYLE=true

# ---- Backend and provider selection: deliberately omitted -------------------
# PODIUM_VECTOR_BACKEND, PODIUM_EMBEDDING_PROVIDER, and PODIUM_EMBEDDING_MODEL
# select a single backend, provider, and model for a real deployment. No test
# reads them: the live suites iterate over every managed backend and every
# embedding provider whose credentials are present below and skip the rest. Set
# the credentials, not a selection. Each provider's model defaults sensibly;
# override one with its own PODIUM_<PROVIDER>_MODEL (e.g. PODIUM_OPENAI_MODEL).

# ---- Pinecone ---------------------------------------------------------------
# PODIUM_PINECONE_API_KEY=
# PODIUM_PINECONE_INDEX=
# PODIUM_PINECONE_HOST=              # auto-resolved from the index when unset
# PODIUM_PINECONE_NAMESPACE=default
# PODIUM_PINECONE_INFERENCE_MODEL=   # set for self-embedding (e.g. multilingual-e5-large)
# PODIUM_PINECONE_CONTROL_PLANE=     # override the control-plane URL

# ---- Weaviate Cloud ---------------------------------------------------------
# PODIUM_WEAVIATE_URL=
# PODIUM_WEAVIATE_API_KEY=
# PODIUM_WEAVIATE_COLLECTION=
# PODIUM_WEAVIATE_VECTORIZER=        # set for self-embedding (e.g. text2vec-weaviate)

# ---- Qdrant Cloud -----------------------------------------------------------
# PODIUM_QDRANT_URL=
# PODIUM_QDRANT_API_KEY=
# PODIUM_QDRANT_COLLECTION=
# PODIUM_QDRANT_INFERENCE_MODEL=     # set for self-embedding

# ---- OpenAI -----------------------------------------------------------------
# OPENAI_API_KEY=
# PODIUM_OPENAI_MODEL=text-embedding-3-small
# PODIUM_OPENAI_BASE_URL=            # override for an OpenAI-compatible endpoint
# PODIUM_OPENAI_ORG=

# ---- Cohere -----------------------------------------------------------------
# COHERE_API_KEY=
# PODIUM_COHERE_MODEL=

# ---- Voyage AI --------------------------------------------------------------
# VOYAGE_API_KEY=
# PODIUM_VOYAGE_MODEL=

# ---- Ollama (self-hosted; no account) ---------------------------------------
# PODIUM_OLLAMA_URL=http://localhost:11434
# PODIUM_OLLAMA_MODEL=nomic-embed-text

# ---- Sigstore (manual signing validation; see RELEASING.md) -----------------
# PODIUM_SIGSTORE_FULCIO_URL=https://fulcio.sigstage.dev
# PODIUM_SIGSTORE_REKOR_URL=https://rekor.sigstage.dev
# PODIUM_SIGSTORE_OIDC_TOKEN=
# PODIUM_SIGSTORE_TRUST_ROOT_PEM_FILE=

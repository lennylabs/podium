# Live integration environment variables. Copy to .env.local (or
# source from your shell rc / direnv) and fill in values for the
# backends you want exercised. Unset variables cause the
# corresponding tests to skip cleanly.
#
# The values below match docker-compose.yml, so `make services-up`
# plus `source .env.local` (or direnv-loaded .envrc) gives you a
# working live-test setup.

# Postgres (drives pkg/store conformance + pgvector fallback)
export PODIUM_POSTGRES_DSN="postgres://podium:podium@localhost:5432/podium?sslmode=disable"
# Optional: separate database for the vector index
export PODIUM_POSTGRES_DSN_VECTOR=""

# S3-compatible object storage (drives pkg/objectstore)
export PODIUM_S3_ENDPOINT="localhost:9000"
export PODIUM_S3_BUCKET="podium"
export PODIUM_S3_REGION=""                          # defaults to us-east-1
export PODIUM_S3_ACCESS_KEY_ID="minioadmin"
export PODIUM_S3_SECRET_ACCESS_KEY="minioadmin"
export PODIUM_S3_USE_SSL="false"

# Sigstore (manual only; release-time verification before any
# release that touches pkg/sign). The release workflow does NOT
# exercise these; see RELEASING.md "Sigstore live tests are
# manual" for the procedure.
export PODIUM_SIGSTORE_FULCIO_URL=""
export PODIUM_SIGSTORE_REKOR_URL=""
export PODIUM_SIGSTORE_OIDC_TOKEN=""
export PODIUM_SIGSTORE_TRUST_ROOT_PEM_FILE=""
